# Core backend configuration
MONGO_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=brandkrt_db
JWT_SECRET=replace_with_a_random_secret_of_at_least_32_characters
APP_ENV=development
APP_VERSION=1.0.0
FRONTEND_URL=http://localhost:3000
# Comma-separated exact origins only; wildcard Vercel preview domains are rejected.
CORS_ORIGINS=http://localhost:3000
COOKIE_SAMESITE=lax
PUBLIC_BACKEND_URL=http://localhost:8001

# MongoDB pool and readiness tuning
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=10000
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=0
MONGO_MAX_IDLE_TIME_MS=60000
READINESS_CACHE_SECONDS=5

# Brand Discovery AI Phase 3A (mock mode consumes no paid API usage)
# Supported providers: mock, openai
AI_PROVIDER=mock
AI_API_KEY=
AI_ALLOWED_MODELS=gpt-5.6-luna
AI_MODEL=gpt-5.6-luna
AI_TIMEOUT_SECONDS=20
AI_MAX_RETRIES=1
AI_MAX_OUTPUT_TOKENS=4000
AI_MAX_REQUESTS_PER_USER_PER_DAY=25
AI_MAX_REQUESTS_PER_IP_PER_MINUTE=10
AI_DAILY_BUDGET_USD=1.00
AI_MAX_ESTIMATED_COST_PER_REQUEST_USD=0.06
AI_MOCK_MODE=true

# Twitch Helix API (OAuth client-credentials; disabled unless explicitly enabled)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_ENABLED=false
TWITCH_TIMEOUT_SECONDS=10
TWITCH_MAX_RESULTS=20

# Optional one-time admin bootstrap used by `python database_setup.py`
ADMIN_EMAIL=admin@brandkrt.com
ADMIN_PASSWORD=replace_with_a_strong_admin_password

# Backend Google OAuth configuration
# Copy this file to .env (or keep the values in your hosting platform environment)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
# Optional aliases accepted by the app
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Email / OTP delivery
EMAIL_PROVIDER=smtp
EMAIL_FROM=BrandKrt <support@brandkrt.com>
SMTP_HOST=smtp.hostinger.com
IMAP_HOST=imap.hostinger.com
SMTP_PORT=465
SMTP_USER=vaibhav@brandkrt.com
SMTP_PASS=your_vaibhav_email_password_here
SMTP_USE_SSL=true
SMTP_USE_TLS=false
EMAIL_CONSOLE_FALLBACK=false
# Alternative to SMTP: set EMAIL_PROVIDER=resend and configure this key.
RESEND_API_KEY=your_resend_api_key_here

# Payments
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# Alternative provider: set PAYMENT_PROVIDER=stripe and configure this key.
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# RazorpayX payouts for creator withdrawals
# Find this in RazorpayX dashboard. It is different from the normal checkout account id.
RAZORPAYX_ACCOUNT_NUMBER=your_razorpayx_account_number_here
RAZORPAYX_BANK_PAYOUT_MODE=IMPS

# MongoDB-backed upload limits used by profile, verification, and chat uploads
MONGO_UPLOAD_MAX_MB=8
UPLOAD_ROOT=./uploads

# Production object storage. Either use CLOUDINARY_URL or all three discrete keys.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
MAX_UPLOAD_MB=10
