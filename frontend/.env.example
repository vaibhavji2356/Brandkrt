# Frontend Google OAuth configuration
# Copy this file to .env.local or .env and rebuild the frontend
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
# Local development only. Leave unset on Vercel to use its same-origin /api rewrite.
REACT_APP_BACKEND_URL=http://localhost:8001
REACT_APP_API_TIMEOUT_MS=75000
REACT_APP_BACKEND_WAKE_TIMEOUT_MS=90000
REACT_APP_BACKEND_POLL_INTERVAL_MS=1500
REACT_APP_BACKEND_HEALTH_TIMEOUT_MS=10000
